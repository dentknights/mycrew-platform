# Database
DATABASE_URL="postgresql://username:password@localhost:5432/mycrew?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CONNECT_CLIENT_ID="ca_..."

# AWS S3 for content storage
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="mycrew-content"
AWS_REGION="us-east-1"
AWS_CLOUDFRONT_URL=""

# Optional: Cloudflare R2 (alternative to S3)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Optional: Mux for video streaming
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""

# Optional: OpenAI for AI features
OPENAI_API_KEY=""

# Optional: PostHog for analytics
POSTHOG_KEY=""
POSTHOG_HOST=""

# Optional: Sentry for error tracking
SENTRY_DSN=""

# App Settings
PLATFORM_FEE_PERCENT="10"
TRIAL_DAYS="90"
MINIMUM_PAYOUT_AMOUNT="50"
